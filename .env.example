# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://fymail_user:CHANGE_ME@localhost:5432/fymail?schema=public

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ops@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_EMAIL=ops@example.com
SMTP_FROM_NAME=FYWarehouse Ops
NEXT_PUBLIC_API_BASE=

# AI Search
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
# Tavily Search API (free 1,000/month, https://app.tavily.com)
TAVILY_API_KEY=tvly-your-api-key
# Brave Search API (free 2,000/month, no credit card, https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=
# Jina Search (free, optional API key for higher limits, https://jina.ai/reader)
# JINA_API_KEY=
# Optional real-time search APIs (leave empty to disable)
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
# BING_SEARCH_API_KEY=

# API Authentication (generate with: openssl rand -hex 32)
API_SECRET_KEY=

# Chat (Claude CLI proxy)
CHAT_ORIGIN_URL=https://your-origin-server.com
CLAUDE_CLI_PATH=/path/to/claude
