{
  "name": "fymail",
  "version": "1.0.0",
  "private": true,
  "description": "FyMail standalone outbound email prospecting app",
  "scripts": {
    "dev": "next dev",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "start": "NEXT_DIST_DIR=.next-build next start",
    "lint": "next lint",
