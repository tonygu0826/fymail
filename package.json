    "@types/nodemailer": "^7.0.11",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "next": "^14.2.35",
    "nodemailer": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.3.1",
    "wrangler": "^4.78.0",
