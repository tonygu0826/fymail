    "db:push": "prisma db push",
    "db:seed": "bash -lc 'set -a && source .env.local && set +a && node prisma/seed.js'",
    "db:studio": "prisma studio",
    "test": "npm run lint"
  },
  "keywords": [
    "nextjs",
    "prisma",
    "fymail"
  ],
  "author": "Codex",
