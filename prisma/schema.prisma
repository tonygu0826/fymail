generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum TemplateLanguage {
  EN
  FR
  DE
  NL
  OTHER
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ContactStatus {
  NEW
  READY
  CONTACTED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignContactStatus {
  PENDING
  QUEUED
  SENT
  FAILED
  SKIPPED
  REPLIED
}

enum EmailDirection {
  OUTBOUND
  INBOUND
}

enum EmailLogStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

enum ApprovalTargetType {
  CAMPAIGN
  SEND
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
  AUTO_REJECTED
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String
  role          UserRole        @default(ADMIN)
  templates     EmailTemplate[]
  contacts      Contact[]
  campaigns     Campaign[]
  searchResults   SearchResult[]
  competitors     Competitor[]
  deepSearchTasks DeepSearchTask[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model EmailTemplate {
  id         String          @id @default(cuid())
  name       String
  slug       String          @unique
  language   TemplateLanguage
  subject    String
  bodyHtml   String          @db.Text
  bodyText   String?         @db.Text
  variables  Json
  status     TemplateStatus  @default(DRAFT)
  notes      String?         @db.Text
  ownerId    String
  owner      User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  campaigns  Campaign[]
  emailLogs  EmailLog[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([ownerId])
  @@index([status])
}

model Contact {
  id              String           @id @default(cuid())
  companyName     String
  contactName     String?
  email           String           @unique
  countryCode     String
  marketRegion    String?
  jobTitle        String?
  source          String?
  status          ContactStatus    @default(NEW)
  priority        Int              @default(0)
  score           Float            @default(0.0)
  tags            Json
  notes           String?          @db.Text
  lastContactedAt DateTime?
  ownerId         String
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  targets         CampaignContact[]
  emailLogs       EmailLog[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([countryCode])
  @@index([status])
  @@index([priority])
  @@index([score])
  @@index([ownerId])
}

model Campaign {
  id             String            @id @default(cuid())
  name           String
  description    String?           @db.Text
  status         CampaignStatus    @default(DRAFT)
  audienceFilter Json?
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  templateId     String
  template       EmailTemplate     @relation(fields: [templateId], references: [id], onDelete: Restrict)
  ownerId        String
  owner          User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  targets        CampaignContact[]
  emailLogs      EmailLog[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
  @@index([templateId])
  @@index([ownerId])
}

model CampaignContact {
  id              String                 @id @default(cuid())
  campaignId      String
  campaign        Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId       String
  contact         Contact                @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status          CampaignContactStatus  @default(PENDING)
  personalization Json?
  sentAt          DateTime?
  openedAt        DateTime?
  repliedAt       DateTime?
  failureReason   String?                @db.Text
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([campaignId, contactId])
  @@index([status])
  @@index([campaignId])
  @@index([contactId])
}

model EmailLog {
  id             String          @id @default(cuid())
  campaignId     String?
  campaign       Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contactId      String?
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  templateId     String?
  template       EmailTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  messageId      String?
  direction      EmailDirection  @default(OUTBOUND)
  status         EmailLogStatus  @default(PENDING)
  subject        String
  recipientEmail String
  provider       String?
  errorMessage   String?         @db.Text
  retryCount     Int             @default(0)
  maxRetries     Int             @default(3)
  scheduledAt    DateTime?       @db.Timestamptz
  nextRetryAt    DateTime?       @db.Timestamptz
  metadata       Json?
  sentAt         DateTime?
  createdAt      DateTime        @default(now())

  @@index([campaignId])
  @@index([contactId])
  @@index([templateId])
  @@index([status])
  @@index([scheduledAt])
  @@index([nextRetryAt])
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Approval {
  id              String              @id @default(cuid())
  targetType      ApprovalTargetType
  targetId        String
  status          ApprovalStatus      @default(PENDING)
  score           Float?
  rulesApplied    Json?
  decisionReason  String?             @db.Text
  decisionBy      String?             // user id if manual decision
  decisionAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([targetType, targetId])
  @@index([status])
}

enum AutomationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}

enum AutomationStep {
  DEDUPLICATION
  SCORING
  PRIORITIZATION
  APPROVAL_GATE
  SENDING
}

model Automation {
  id          String           @id @default(cuid())
  name        String
  description String?          @db.Text
  steps       Json             // array of AutomationStep
  config      Json?
  isActive    Boolean          @default(true)
  runs        AutomationRun[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model AutomationRun {
  id              String           @id @default(cuid())
  automationId    String?
  automation      Automation?      @relation(fields: [automationId], references: [id], onDelete: SetNull)
  status          AutomationStatus @default(PENDING)
  stepsCompleted  Json             // array of AutomationStep
  errorMessage    String?          @db.Text
  startedAt       DateTime?
  completedAt     DateTime?
  metrics         Json?            // e.g., contacts processed, sent, etc.
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([automationId])
  @@index([status])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  SEND
  SEND_RETRY
  SYSTEM
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entityType  String      // e.g., "EmailTemplate", "Contact", "Campaign", "Approval", "EmailLog"
  entityId    String?
  userId      String?     // user id if performed by user
  userEmail   String?     // user email for quick reference
  details     Json?       // e.g., old values, new values, metadata
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}

enum DeepSearchStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model DeepSearchTask {
  id              String           @id @default(cuid())
  status          DeepSearchStatus @default(PENDING)
  config          Json
  progress        Json?
  totalCompanies  Int              @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?          @db.Text
  ownerId         String
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  results         DeepSearchCompany[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([ownerId])
}

model DeepSearchCompany {
  id              String          @id @default(cuid())
  taskId          String
  task            DeepSearchTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  companyName     String
  domain          String?
  website         String?
  country         String?
  services        String[]
  email           String?
  phone           String?
  address         String?
  contactPageUrl  String?
  description     String?         @db.Text
  source          String
  scrapeStatus    String          @default("pending")
  scrapeError     String?
  confidence      Float           @default(0.0)
  rawData         Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([taskId, domain])
  @@index([taskId])
  @@index([domain])
  @@index([scrapeStatus])
  @@index([country])
}

model SearchResult {
  id              String   @id @default(cuid())
  searchId        String   @unique
  query           String
  filters         Json?
  companies       Json
  totalResults    Int      @default(0)
  source          String   @default("local_dataset")
  realTimeSuccess Boolean  @default(false)
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([ownerId])
  @@index([query])
  @@index([createdAt])
}

enum CompetitorThreatLevel {
  LOW
  MEDIUM
  HIGH
}

enum CompetitorMarketPosition {
  LEADER
  CHALLENGER
  FOLLOWER
  NEW_ENTRANT
}

model Competitor {
  id              String                   @id @default(cuid())
  name            String
  marketPosition  CompetitorMarketPosition
  threatLevel     CompetitorThreatLevel
  opportunityScore Int                     @default(50)
  services        String[]
  description     String?                  @db.Text
  strengths       String[]
  weaknesses      String[]
  marketShare     String?
  growthRate      String?
  lastUpdated     DateTime                 @default(now())
  source          String                   @default("manual")
  ownerId         String
  owner           User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([marketPosition])
  @@index([threatLevel])
  @@index([opportunityScore])
  @@index([ownerId])
}
